<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Workshop Buchungssystem</title>
    <style>
        :root {
            --primary-color: #0056b3;
            --primary-hover: #004494;
            --bg-color: #f8f9fa;
            --border-color: #dee2e6;
            --slot-hover: #e9ecef;
            --font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Verhindert globales Scrollen und baut das Layout als Spalte auf */
        body {
            margin: 0;
            padding: 0;
            font-family: var(--font-family);
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
            background-color: #fff;
            color: #333;
        }

        /* Globaler Header */
        .main-header {
            background-color: var(--primary-color);
            color: white;
            padding: 15px 20px;
            flex-shrink: 0; /* Header schrumpft nicht */
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            z-index: 10;
        }

        .main-header h1 {
            margin: 0;
            font-size: 22px;
            font-weight: 600;
        }

        /* Wrapper für den 2/3 zu 1/3 Bereich */
        #content-wrapper {
            display: flex;
            flex: 1;
            min-height: 0; /* Wichtig, damit Inhalte sich zusammenstauchen und nicht scrollen */
        }

        /* Linke Seite: Kalender (2/3) - KEIN SCROLLEN */
        #left-panel {
            flex: 2;
            display: flex;
            flex-direction: column;
            padding: 15px 20px;
            overflow: hidden; /* Scrollen deaktiviert */
        }

        /* Rechte Seite: Details (1/3) - SCROLLEN ERLAUBT */
        #right-panel {
            flex: 1;
            background-color: var(--bg-color);
            border-left: 1px solid var(--border-color);
            padding: 25px;
            overflow-y: auto; /* Hier darf gescrollt werden */
            box-shadow: -2px 0 10px rgba(0,0,0,0.05);
        }

        /* Kalender Header (Monatswechsel) */
        .calendar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            flex-shrink: 0;
        }

        .calendar-header button {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 8px 15px;
            font-size: 15px;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.2s;
        }

        .calendar-header button:hover {
            background-color: var(--primary-hover);
        }

        .calendar-header h2 {
            margin: 0;
            font-size: 22px;
        }

        /* Wochentage Anzeige */
        .weekdays {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 8px;
            margin-bottom: 8px;
            font-weight: bold;
            text-align: center;
            color: #555;
            flex-shrink: 0;
            font-size: 14px;
        }

        /* Kalender Raster - Passt sich dynamisch an */
        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            /* grid-template-rows wird dynamisch von JS gesetzt (je nach Anzahl der Wochen) */
            gap: 8px;
            flex-grow: 1;
            min-height: 0; /* Zwingt das Grid, in der verfügbaren Höhe zu bleiben */
        }

        .day-cell {
            border: 1px solid var(--border-color);
            border-radius: 6px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background-color: #fff;
            min-height: 0; /* Wichtig für die Skalierung */
        }

        .empty-cell {
            background-color: transparent;
            border: none;
        }

        .day-header {
            background-color: var(--bg-color);
            padding: 4px;
            text-align: center;
            font-weight: bold;
            border-bottom: 1px solid var(--border-color);
            font-size: 13px;
            flex-shrink: 0;
        }

        .time-slot {
            flex: 1; /* Verteilt die verbleibende Höhe gleichmäßig auf die 3 Stunden */
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2px 5px;
            text-align: center;
            font-size: 12px;
            cursor: pointer;
            border-bottom: 1px solid var(--border-color);
            transition: all 0.2s;
            min-height: 0;
        }

        .time-slot:last-child {
            border-bottom: none;
        }

        .time-slot:hover {
            background-color: var(--slot-hover);
        }

        .time-slot.selected {
            background-color: var(--primary-color);
            color: white;
            font-weight: bold;
        }

        /* Detail Panel Styling */
        #placeholder-text {
            text-align: center;
            color: #777;
            margin-top: 50px;
            font-size: 16px;
        }

        #booking-form-container {
            display: none;
        }

        .booking-header {
            margin-top: 0;
            color: var(--primary-color);
            margin-bottom: 20px;
        }

        .selection-info {
            background: #fff;
            padding: 15px;
            border-radius: 6px;
            border: 1px solid var(--border-color);
            margin-bottom: 20px;
        }

        .selection-info p {
            margin: 5px 0;
            font-size: 14px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            font-size: 14px;
        }

        .form-group input, .form-group textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            box-sizing: border-box;
            font-family: var(--font-family);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 80px;
        }

        .submit-btn {
            background-color: #28a745;
            color: white;
            border: none;
            padding: 12px;
            width: 100%;
            font-size: 16px;
            font-weight: bold;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 5px;
        }

        .submit-btn:hover {
            background-color: #218838;
        }
    </style>
</head>
<body>

    <!-- Globaler Header -->
    <header class="main-header">
        <h1>Workshop Buchung</h1>
    </header>

    <!-- Wrapper für das Zwei-Spalten-Layout -->
    <div id="content-wrapper">
        
        <!-- Linke Seite: Kalender -->
        <div id="left-panel">
            <div class="calendar-header">
                <button onclick="changeMonth(-1)">&#9664; Zurück</button>
                <h2 id="month-year-display">Monat Jahr</h2>
                <button onclick="changeMonth(1)">Vor &#9654;</button>
            </div>
            
            <div class="weekdays">
                <div>Montag</div>
                <div>Dienstag</div>
                <div>Mittwoch</div>
                <div>Donnerstag</div>
                <div>Freitag</div>
            </div>

            <div class="calendar-grid" id="calendar-grid">
                <!-- Wird von JavaScript generiert -->
            </div>
        </div>

        <!-- Rechte Seite: Detailansicht -->
        <div id="right-panel">
            <div id="placeholder-text">
                Bitte wähle im Kalender links einen freien Zeitraum aus, um einen Workshop anzufragen.
            </div>

            <div id="booking-form-container">
                <h3 class="booking-header">Details eintragen</h3>
                
                <div class="selection-info">
                    <p><strong>Datum:</strong> <span id="display-date">-</span></p>
                    <p><strong>Zeitraum:</strong> <span id="display-slot">-</span></p>
                </div>

                <form id="workshop-form" onsubmit="submitForm(event)">
                    <div class="form-group">
                        <label for="name">Name / Lehrkraft</label>
                        <input type="text" id="name" required placeholder="Dein Name">
                    </div>
                    <div class="form-group">
                        <label for="email">E-Mail Adresse</label>
                        <input type="email" id="email" required placeholder="deine@email.de">
                    </div>
                    <div class="form-group">
                        <label for="class">Klasse / Lerngruppe</label>
                        <input type="text" id="class" required placeholder="z.B. 9b">
                    </div>
                    <div class="form-group">
                        <label for="topic">Gewünschtes Thema / Bemerkungen</label>
                        <textarea id="topic" placeholder="Worum soll es im Workshop gehen?"></textarea>
                    </div>
                    <button type="submit" class="submit-btn">Workshop jetzt anfragen</button>
                </form>
            </div>
        </div>

    </div>

    <script>
        let currentDate = new Date();
        let selectedSlotElement = null;

        const monthNames = [
            "Januar", "Februar", "März", "April", "Mai", "Juni", 
            "Juli", "August", "September", "Oktober", "November", "Dezember"
        ];

        const timeSlots = ['1./2. Stunde', '3./4. Stunde', '5./6. Stunde'];

        // Initialer Aufruf
        renderCalendar();

        function renderCalendar() {
            const year = currentDate.getFullYear();
            const month = currentDate.getMonth();

            document.getElementById('month-year-display').innerText = `${monthNames[month]} ${year}`;

            const grid = document.getElementById('calendar-grid');
            grid.innerHTML = ''; 

            const firstDayOfMonth = new Date(year, month, 1);
            const lastDayOfMonth = new Date(year, month + 1, 0);

            let startDayOfWeek = firstDayOfMonth.getDay();
            
            // Leere Zellen berechnen
            let emptyCellsCount = 0;
            if (startDayOfWeek >= 1 && startDayOfWeek <= 5) {
                emptyCellsCount = startDayOfWeek - 1; 
            } 

            let totalRenderedCells = emptyCellsCount;

            // Leere Platzhalter am Monatsanfang einfügen
            for (let i = 0; i < emptyCellsCount; i++) {
                const emptyCell = document.createElement('div');
                emptyCell.className = 'day-cell empty-cell';
                grid.appendChild(emptyCell);
            }

            // Tage erstellen
            for (let d = 1; d <= lastDayOfMonth.getDate(); d++) {
                const currentDayObj = new Date(year, month, d);
                const dayOfWeek = currentDayObj.getDay();

                // Nur Werktage (Mo-Fr)
                if (dayOfWeek >= 1 && dayOfWeek <= 5) {
                    const dayCell = createDayCell(currentDayObj);
                    grid.appendChild(dayCell);
                    totalRenderedCells++;
                }
            }

            // Berechnen, wie viele Zeilen (Wochen) wir brauchen, damit das Grid den Platz perfekt aufteilt
            // In der Regel sind es 4 oder 5 Wochen pro Monat bei reiner Mo-Fr Ansicht
            const numRows = Math.ceil(totalRenderedCells / 5);
            grid.style.gridTemplateRows = `repeat(${numRows}, minmax(0, 1fr))`;
        }

        function createDayCell(dateObj) {
            const cell = document.createElement('div');
            cell.className = 'day-cell';

            // Tag Header
            const header = document.createElement('div');
            header.className = 'day-header';
            header.innerText = dateObj.getDate() + '.';
            cell.appendChild(header);

            // Stundenblöcke
            timeSlots.forEach(slotName => {
                const slotDiv = document.createElement('div');
                slotDiv.className = 'time-slot';
                slotDiv.innerText = slotName;
                
                slotDiv.onclick = function() {
                    selectSlot(slotDiv, dateObj, slotName);
                };
                
                cell.appendChild(slotDiv);
            });

            return cell;
        }

        function selectSlot(element, dateObj, slotName) {
            if (selectedSlotElement) {
                selectedSlotElement.classList.remove('selected');
            }
            
            element.classList.add('selected');
            selectedSlotElement = element;

            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            const formattedDate = dateObj.toLocaleDateString('de-DE', options);

            document.getElementById('placeholder-text').style.display = 'none';
            document.getElementById('booking-form-container').style.display = 'block';
            
            document.getElementById('display-date').innerText = formattedDate;
            document.getElementById('display-slot').innerText = slotName;
        }

        function changeMonth(direction) {
            currentDate.setMonth(currentDate.getMonth() + direction);
            
            if (selectedSlotElement) {
                selectedSlotElement = null;
                document.getElementById('placeholder-text').style.display = 'block';
                document.getElementById('booking-form-container').style.display = 'none';
            }

            renderCalendar();
        }

        function submitForm(event) {
            event.preventDefault(); 
            
            const name = document.getElementById('name').value;
            const date = document.getElementById('display-date').innerText;
            const slot = document.getElementById('display-slot').innerText;

            alert(`Vielen Dank, ${name}!\n\nDeine Workshop-Anfrage für ${date} (${slot}) wurde erfolgreich simuliert.`);
            
            document.getElementById('workshop-form').reset();
            if (selectedSlotElement) selectedSlotElement.classList.remove('selected');
            document.getElementById('placeholder-text').style.display = 'block';
            document.getElementById('booking-form-container').style.display = 'none';
            selectedSlotElement = null;
        }
    </script>
</body>
</html>
