<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Code Bestätigen - Workshop Buchung</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        /* Gleiches Styling wie auf der Login-Seite für Konsistenz */
        :root {
            --primary-color: #0056b3;
            --primary-hover: #004494;
            --bg-color: #f8f9fa;
            --border-color: #dee2e6;
            --font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: var(--font-family);
            background-color: var(--bg-color);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .auth-card {
            background: white;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
            box-sizing: border-box;
            text-align: center;
        }

        h2 { margin-top: 0; color: var(--primary-color); margin-bottom: 10px; }
        
        p.description { color: #555; font-size: 14px; margin-bottom: 25px; line-height: 1.5; }

        .form-group { margin-bottom: 20px; text-align: left; }
        .form-group label { display: block; margin-bottom: 8px; font-weight: bold; font-size: 14px; }
        .form-group input { 
            width: 100%; padding: 12px; border: 1px solid var(--border-color); 
            border-radius: 4px; box-sizing: border-box; font-size: 18px; 
            letter-spacing: 2px; text-align: center; 
        }

        .submit-btn {
            background-color: #28a745; color: white; border: none; padding: 12px;
            width: 100%; font-size: 16px; font-weight: bold; border-radius: 5px;
            cursor: pointer; transition: background-color 0.2s;
        }
        .submit-btn:hover { background-color: #218838; }
        .submit-btn:disabled { background-color: #888; cursor: not-allowed; }

        .back-link {
            display: inline-block; margin-top: 20px; color: var(--primary-color);
            text-decoration: none; font-size: 14px;
        }
        .back-link:hover { text-decoration: underline; }

        #error-msg { color: red; font-size: 14px; margin-top: 10px; display: none; }
    </style>
</head>
<body>

    <div class="auth-card">
        <h2>Code eingeben</h2>
        <p class="description">
            Wir haben einen 6-stelligen Code an <br>
            <strong id="display-email"></strong> gesendet.
        </p>
        
        <form id="verify-form" onsubmit="verifyCode(event)">
            <div class="form-group">
                <label for="code">Einmalcode</label>
                <input type="text" id="code" required placeholder="123456" maxlength="6" autocomplete="one-time-code">
            </div>
            
            <button type="submit" class="submit-btn" id="submit-btn">Bestätigen & Einloggen</button>
            <div id="error-msg">Der Code ist falsch oder abgelaufen.</div>
        </form>

        <a href="index.html" class="back-link">&larr; Andere E-Mail verwenden</a>
    </div>

    <script>
        // TRAGE HIER DEINE SUPABASE DATEN EIN:
        const SUPABASE_URL = 'https://yrqjgyjsivurlcrwnuhp.supabase.co';
        const SUPABASE_ANON_KEY = 'sb_publishable_9diy53NKbmLhqWWkynZ0mg_UMJgtB2e';
        const supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

        // Prüfen ob wir von login.html kommen
        const userEmail = sessionStorage.getItem('authEmail');
        if (!userEmail) {
            window.location.href = 'login.html'; // Falls keine E-Mail bekannt ist, zurückleiten
        } else {
            document.getElementById('display-email').innerText = userEmail;
        }

        async function verifyCode(event) {
            event.preventDefault();
            
            const code = document.getElementById('code').value;
            const btn = document.getElementById('submit-btn');
            const errorMsg = document.getElementById('error-msg');
            
            btn.disabled = true;
            btn.innerText = "Überprüfe...";
            errorMsg.style.display = 'none';

            // OTP Code via Supabase verifizieren
            const { data, error } = await supabaseClient.auth.verifyOtp({
                email: userEmail,
                token: code,
                type: 'email'
            });

            if (error) {
                console.error(error);
                errorMsg.innerText = "Fehler: " + (error.message || "Code ungültig.");
                errorMsg.style.display = 'block';
                btn.disabled = false;
                btn.innerText = "Bestätigen & Einloggen";
            } else {
                // Login erfolgreich! (Session Token ist nun lokal bei Supabase gespeichert)
                sessionStorage.removeItem('authEmail'); // Aufräumen
                
                // Weiterleitung zur Kalender-Ansicht!
                window.location.href = 'calender_intern.html'; 
            }
        }
    </script>
</body>
</html>
